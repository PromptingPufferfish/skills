{
  "version": "1.0.0",
  "description": "智能模型选择规则配置",
  "models": {
    "flash": {
      "id": "zai/glm-4.7-flash",
      "description": "快速响应，适合简单问题",
      "use_cases": ["简单问答", "快速查询", "闲聊"],
      "max_tokens": 4000
    },
    "main": {
      "id": "zai/glm-5",
      "description": "主力模型，平衡质量与速度",
      "use_cases": ["常规对话", "分析任务", "决策支持"],
      "max_tokens": 8000
    },
    "coding": {
      "id": "aihubmix/coding-glm-5-free",
      "description": "编程专用，处理代码任务",
      "use_cases": ["代码生成", "代码审查", "技术问题"],
      "max_tokens": 8000
    },
    "vision": {
      "id": "aihubmix/gemini-3.1-flash-image-preview-free",
      "description": "视觉理解，处理图片",
      "use_cases": ["图片分析", "截图解读", "视觉问答"],
      "max_tokens": 8000
    },
    "complex": {
      "id": "bailian/qwen3-max-2026-01-23",
      "description": "复杂推理，深度分析",
      "use_cases": ["复杂推理", "深度分析", "架构设计"],
      "max_tokens": 16000
    },
    "long-context": {
      "id": "bailian/kimi-k2.5",
      "description": "超长上下文，256k窗口",
      "use_cases": ["长对话", "超长文档", "上下文临界"],
      "max_tokens": 16000,
      "context_window": 256000
    }
  },
  "context_switch_strategy": {
    "enabled": true,
    "description": "基于上下文使用率的自动模型切换策略",
    "rules": [
      {
        "name": "长上下文切换",
        "trigger": "context_usage",
        "threshold": 85,
        "consecutive_hits": 2,
        "target_model": "long-context",
        "description": "连续2次上下文超过85%时切换到Kimi长上下文模型"
      },
      {
        "name": "视觉模型切换",
        "trigger": "vision_detected",
        "immediate": true,
        "target_model": "vision",
        "description": "检测到图片立即切换到视觉模型"
      },
      {
        "name": "代码模型切换",
        "trigger": "code_detected",
        "immediate": true,
        "target_model": "coding",
        "description": "检测到代码任务立即切换到编程模型"
      },
      {
        "name": "复杂模型切换",
        "trigger": "complexity_score",
        "threshold": 8,
        "target_model": "complex",
        "description": "复杂度评分≥8时切换到Complex模型"
      },
      {
        "name": "快速模型切换",
        "trigger": "complexity_score",
        "threshold": 3,
        "comparison": "lte",
        "target_model": "flash",
        "description": "复杂度评分≤3时切换到Flash模型"
      }
    ],
    "cooldown": {
      "enabled": true,
      "duration_minutes": 10,
      "description": "切换后10分钟内不再自动切换，避免频繁切换"
    },
    "notification": {
      "enabled": true,
      "message": "检测到上下文接近限制，已自动切换到长上下文模型（Kimi 256k）",
      "description": "切换时通知用户"
    }
  },
  "rules": {
    "complexity_keywords": {
      "simple": ["什么", "怎么", "是否", "在哪", "几点", "多少"],
      "moderate": ["分析", "对比", "评估", "解释", "说明", "建议"],
      "complex": ["设计", "架构", "优化", "重构", "深度", "全面"]
    },
    "feature_detection": {
      "code_patterns": ["```", "function", "class", "import", "export", "const", "let", "var", "写", "组件", "代码", "React", "Vue", "JavaScript", "Python", "API", "接口", "实现", "开发"],
      "vision_keywords": ["图片", "截图", "看图", "识别", "视觉", "界面", "照片", "图像"],
      "long_content": { "threshold": 500, "description": "消息长度超过500字符" }
    },
    "scoring": {
      "length_weight": 0.3,
      "keyword_weight": 0.4,
      "code_weight": 0.2,
      "vision_weight": 0.1
    }
  },
  "thresholds": {
    "flash_max_score": 3,
    "main_max_score": 6,
    "complex_min_score": 8
  }
}

